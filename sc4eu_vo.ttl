    dcterms:identifier "04ebacdf-8b1c-46df-81fd-1665df6a7594";
    rdfs:label "Participant";
    dcterms:description "Within the SC4EU project, a Participant is a company that fills in the SC4EU survey";
    rdfs:seeAlso "Partner";
    ex:status "draft";
    dcterms:created "2024-11-20"^^xsd:date;
